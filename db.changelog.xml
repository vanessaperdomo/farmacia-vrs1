    <!-- =====================================================
         CAMBIOS A PRODUCCIÓN
         Autor: laura
         Fecha: 2026-03-18
    ====================================================== -->

    <!-- 10. Agregar fecha_vencimiento a medicamento -->
    <changeSet id="10" author="laura">
        <comment>Cambio a producción: agrega fecha de vencimiento al medicamento</comment>
        <addColumn tableName="medicamento">
            <column name="fecha_vencimiento"
                    type="date"
                    remarks="Fecha de expiración del lote actual del medicamento"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="medicamento" columnName="fecha_vencimiento"/>
        </rollback>
    </changeSet>

    <!-- 11. Agregar descuento a detalle_venta -->
    <changeSet id="11" author="laura">
        <comment>Cambio a producción: agrega columna de descuento al detalle de venta</comment>
        <addColumn tableName="detalle_venta">
            <column name="descuento"
                    type="numeric(5,2)"
                    defaultValueNumeric="0.00"
                    remarks="Porcentaje de descuento aplicado (ej: 10.00 = 10%)">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="detalle_venta" columnName="descuento"/>
        </rollback>
    </changeSet>

    <!-- 12. Nuevo cambio a producción -->
    <changeSet id="12" author="vanessa">
        <comment>Cambio a producción: agrega columna dirección al cliente</comment>
        <addColumn tableName="cliente">
            <column name="direccion" type="varchar(200)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="cliente" columnName="direccion"/>
        </rollback>
    </changeSet>

</databaseChangeLog>