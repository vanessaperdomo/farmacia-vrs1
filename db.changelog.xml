<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <!-- =====================================================
         FARMACIA DB — Changelog único
         Autor: laura
         Descripción: Versionado completo de la base de datos
                      de una farmacia (DDL + DML en un solo archivo)
    ====================================================== -->

    <!-- 1. Tabla: categoria -->
    <changeSet id="1" author="laura">
        <createTable tableName="categoria">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="descripcion" type="text"/>
        </createTable>
    </changeSet>

    <!-- 2. Tabla: proveedor -->
    <changeSet id="2" author="laura">
        <createTable tableName="proveedor">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="nit" type="varchar(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="telefono" type="varchar(20)"/>
            <column name="email" type="varchar(150)">
                <constraints unique="true"/>
            </column>
            <column name="ciudad" type="varchar(100)"/>
        </createTable>
    </changeSet>

    <!-- 3. Tabla: medicamento -->
    <changeSet id="3" author="laura">
        <createTable tableName="medicamento">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="principio_activo" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="categoria_id" type="int">
                <constraints foreignKeyName="fk_medicamento_categoria"
                             referencedTableName="categoria"
                             referencedColumnNames="id"/>
            </column>
            <column name="proveedor_id" type="int">
                <constraints foreignKeyName="fk_medicamento_proveedor"
                             referencedTableName="proveedor"
                             referencedColumnNames="id"/>
            </column>
            <column name="forma_farmaceutica" type="varchar(50)"/>
            <column name="concentracion" type="varchar(50)"/>
            <column name="precio_venta" type="numeric(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="stock" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="requiere_receta" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 4. Tabla: cliente -->
    <changeSet id="4" author="laura">
        <createTable tableName="cliente">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="apellido" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="numero_documento" type="varchar(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="telefono" type="varchar(20)"/>
            <column name="email" type="varchar(150)">
                <constraints unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 5. Tabla: venta -->
    <changeSet id="5" author="laura">
        <createTable tableName="venta">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cliente_id" type="int">
                <constraints foreignKeyName="fk_venta_cliente"
                             referencedTableName="cliente"
                             referencedColumnNames="id"/>
            </column>
            <column name="fecha_venta" type="timestamp" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="total" type="numeric(14,2)">
                <constraints nullable="false"/>
            </column>
            <column name="metodo_pago" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- 6. Tabla: detalle_venta -->
    <changeSet id="6" author="laura">
        <createTable tableName="detalle_venta">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="venta_id" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_detalle_venta"
                             referencedTableName="venta"
                             referencedColumnNames="id"/>
            </column>
            <column name="medicamento_id" type="int">
                <constraints nullable="false"
                             foreignKeyName="fk_detalle_medicamento"
                             referencedTableName="medicamento"
                             referencedColumnNames="id"/>
            </column>
            <column name="cantidad" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="precio_unitario" type="numeric(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="subtotal" type="numeric(14,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

